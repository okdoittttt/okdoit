{
  "name": "okdoit-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "okdoit 데스크탑 앱 (Electron + React). Python sidecar 를 spawn 해서 사용자에게 GUI 를 제공한다.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/wait-on": "^5.3.4",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.0",
    "electron": "^33.2.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "zustand": "^5.0.12"
  }
}
