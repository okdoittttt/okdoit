# LLM 프로바이더 선택: anthropic | gemini | ollama
LLM_PROVIDER=anthropic

# LLM 모델명
# anthropic: claude-sonnet-4-6, claude-haiku-4-5-20251001
# gemini:    gemini-2.0-flash, gemini-2.5-pro
# ollama:    llama3.2, gemma3, qwen2.5
LLM_MODEL=claude-sonnet-4-6

# Anthropic API (LLM_PROVIDER=anthropic 일 때 필수)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google AI Studio API 키 (LLM_PROVIDER=gemini 일 때 필수)
# GOOGLE_API_KEY=your-google-api-key-here

# Ollama 서버 주소 (LLM_PROVIDER=ollama 일 때, 기본값: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# 브라우저 헤드리스 모드 (false로 설정하면 브라우저 창이 열림, 기본값: true)
# BROWSER_HEADLESS=false

# ── LangSmith (MLOps 관측 및 프롬프트 테스트) ──────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key-here
# LANGCHAIN_PROJECT=okdoit
